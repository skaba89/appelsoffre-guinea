# ─── TenderFlow Guinea — Variables d'environnement ───────────────────────────

# Base de données SQLite (chemin relatif au projet)
DATABASE_URL="file:./dev.db"

# Application
NEXT_PUBLIC_APP_NAME="TenderFlow Guinea"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Authentification
NEXTAUTH_SECRET="tenderflow-guinea-dev-secret-change-in-prod"
NEXTAUTH_URL="http://localhost:3000"

# Mode démo (bypass auth pour développement)
NEXT_PUBLIC_DEMO_MODE="true"

# IA / LLM
ZAI_API_KEY=""

# Crawling
CRAWL_INTERVAL_SECONDS="3600"
CRAWL_MAX_CONCURRENT="3"

# Notifications
NOTIFICATION_REALTIME_ENABLED="true"
NOTIFICATION_POLL_INTERVAL="15000"

# Export
EXPORT_MAX_RECORDS="10000"

# Webhooks
WEBHOOK_SECRET=""
WEBHOOK_MAX_RETRIES="3"

# Email (optionnel)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@tenderflow-gn.com"
