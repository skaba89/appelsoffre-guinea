# ═══════════════════════════════════════════════════════════════
# TenderFlow Guinea — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values before running.

# ─── General ─────────────────────────────────────────────────
APP_NAME=TenderFlow Guinea
APP_VERSION=1.0.0
ENVIRONMENT=development

# ─── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tenderflow:tfsecret@localhost:5432/tenderflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── MinIO / S3 Storage ─────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tenderflow-docs
MINIO_SECURE=false

# ─── Authentication ──────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── LLM Provider ────────────────────────────────────────────
# Support multiple providers: openai, anthropic, ollama
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─── Embeddings ──────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Crawler ─────────────────────────────────────────────────
CRAWLER_USER_AGENT=TenderFlow-Guinea/1.0 (compatible; bot)
CRAWLER_MAX_CONCURRENT=5
CRAWLER_REQUEST_DELAY=2
CRAWLER_TIMEOUT=30

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Email (for alerts) ─────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@tenderflow-gn.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=noreply@tenderflow-gn.com

# ─── Billing (Stripe) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_BUSINESS_PRICE_ID=price_xxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxx
